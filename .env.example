BACKEND_PORT=8080
FRONTEND_PORT=3000

# Render-style deployment variables
# Render sets PORT for each web service. Local Docker Compose keeps using BACKEND_PORT/FRONTEND_PORT above.
PORT=8080
TRAFFICLAB_DB_HOST=localhost
TRAFFICLAB_DB_PORT=5432
TRAFFICLAB_DB_NAME=trafficlab
TRAFFICLAB_DB_USER=trafficlab
TRAFFICLAB_DB_PASSWORD=trafficlab
SPRING_DATA_REDIS_URL=redis://localhost:6379
TRAFFICLAB_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
